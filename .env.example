# BTG ConnectAI — Variables de Entorno (ejemplo)
# Copiar a .env y configurar con valores reales

# ============================================================
# AWS
# ============================================================
AWS_REGION=us-east-1
AWS_PROFILE=btg-sandbox

# ============================================================
# Twilio (WhatsApp Sandbox)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ============================================================
# DynamoDB Tables
# ============================================================
CONSENT_TABLE_NAME=btgconnectai-sandbox-consent-store
AUTH_SESSION_TABLE_NAME=btgconnectai-sandbox-auth-session
OTP_TABLE_NAME=btgconnectai-sandbox-otp-store

# ============================================================
# S3 Buckets
# ============================================================
AUDIO_TEMP_BUCKET=btgconnectai-sandbox-audio-temp
STATEMENT_BUCKET=btgconnectai-sandbox-statements
LOGIN_PAGE_BUCKET=btgconnectai-sandbox-login-page
LAMBDA_ARTIFACTS_BUCKET=btgconnectai-sandbox-artifacts

# ============================================================
# SQS Queues
# ============================================================
INBOUND_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/btgconnectai-sandbox-inbound-messages.fifo

# ============================================================
# Step Functions
# ============================================================
STATE_MACHINE_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:btgconnectai-sandbox-transfer-breb

# ============================================================
# Amazon Bedrock
# ============================================================
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_GUARDRAIL_ID=xxxxxxxxxx
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ============================================================
# Resend (Email)
# ============================================================
RESEND_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:BTGConnectAI-sandbox-resend-XXXXXX

# ============================================================
# Auth Service
# ============================================================
AUTH_SERVICE_URL=https://xxxxxxx.lambda-url.us-east-1.on.aws/
LOGIN_PAGE_URL=https://btgconnectai-sandbox-login-page.s3.amazonaws.com/index.html

# ============================================================
# Lambda Powertools
# ============================================================
POWERTOOLS_SERVICE_NAME=btg-connectai
POWERTOOLS_LOG_LEVEL=INFO
